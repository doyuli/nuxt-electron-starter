{
  "name": "nuxt-electron-starter",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "A lightweight Electron + Nuxt + TypeScript starter with a secure preload IPC bridge.",
  "author": "doyuli",
  "main": "dist/main/index.cjs",
  "scripts": {
    "setup": "node scripts/setup.js",
    "dev": "concurrently -k -n renderer,electron-build,electron -c blue,green,magenta \"pnpm dev:renderer\" \"pnpm dev:electron\" \"pnpm dev:app\"",
    "dev:app": "wait-on http://localhost:8086 dist/main/index.cjs dist/preload/index.cjs && ELECTRON_RENDERER_URL=http://localhost:8086 electron .",
    "dev:renderer": "nuxt dev -p 8086",
    "dev:electron": "tsdown --watch",
    "build": "pnpm build:renderer && pnpm build:electron && electron-builder",
    "build:renderer": "nuxt build",
    "build:electron": "tsdown",
    "generate:renderer": "nuxt generate",
    "preview:renderer": "nuxt preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "postinstall": "nuxt prepare && simple-git-hooks"
  },
  "dependencies": {
    "@lucide/vue": "^1.23.0",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "nuxt": "^4.4.8",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "@vueuse/nuxt": "14.3.0",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "eslint-plugin-format": "^2.0.1",
    "lint-staged": "^17.0.8",
    "picocolors": "^1.1.1",
    "shadcn-nuxt": "2.7.4",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.2",
    "tsdown": "^0.22.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "commit-msg": "node scripts/verify-commit.js"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
